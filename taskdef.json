{
  "family": "apache-dev-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "apache-container",
      "image": "IMAGE1_NAME",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80
        }
      ],
      "environment": [
        {
          "name": "ENVIRONMENT",
          "value": "DEV"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}